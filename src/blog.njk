---
layout: base.njk
title: "Blog"
permalink: "/blog/index.html"
---
<h1>Le blog</h1>
<p class="meta">Articles publiés au fil de l'inspiration</p>
{% set posts = collections.blog | reverse %}
{% if posts.length == 0 %}<p>Aucun article pour l'instant.</p>{% endif %}
{% for post in posts %}
  <div style="border-bottom:1px solid #e7ded1;padding:22px 0">
    <div class="meta" style="margin-bottom:6px">{{ post.date | dateFR }}</div>
    <h2 style="margin-bottom:6px"><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
    {% if post.data.excerpt %}<p style="margin:0">{{ post.data.excerpt }}</p>{% endif %}
  </div>
{% endfor %}
